@startuml
title Diagramma Classi - Repository Casa Intelligente (Persistenza JSON)

interface RepositoryUtenti {
  +trovaPerEmail(email: String): Utente
}

interface RepositoryStanze {
  +trovaTutti(): List<Stanza>
  +salva(stanza: Stanza)
  +aggiorna(stanza: Stanza)
  +elimina(id: int)
}

interface RepositoryDispositivi {
  +trovaTutti(): List<Dispositivo>
  +trovaPerId(id: int): Dispositivo
  +salva(dispositivo: Dispositivo)
  +aggiorna(dispositivo: Dispositivo)
  +elimina(id: int)
  +aggiornaStanza(idDispositivo: int, idStanza: int)
  +trovaOffline(): List<Dispositivo>
}

interface RepositoryAutomazioni {
  +trovaTutti(): List<RegolaAutomazione>
  +trovaAttive(): List<RegolaAutomazione>
  +salva(regola: RegolaAutomazione)
  +aggiorna(regola: RegolaAutomazione)
  +elimina(id: int)
}

interface RepositoryEventi {
  +cerca(filtro: String): List<Evento>
  +salva(evento: Evento)
  +aggrega(filtro: String): List<Evento>
}

interface RepositoryDatiSistema {
  +estraiDati(): String
}

class RepositoryUtentiJSON {
}
class RepositoryStanzeJSON {
}
class RepositoryDispositiviJSON {
}
class RepositoryAutomazioniJSON {
}
class RepositoryEventiJSON {
}
class RepositoryDatiSistemaJSON {
}

RepositoryUtentiJSON ..|> RepositoryUtenti
RepositoryStanzeJSON ..|> RepositoryStanze
RepositoryDispositiviJSON ..|> RepositoryDispositivi
RepositoryAutomazioniJSON ..|> RepositoryAutomazioni
RepositoryEventiJSON ..|> RepositoryEventi
RepositoryDatiSistemaJSON ..|> RepositoryDatiSistema

class ServizioUtenti
class ServizioDashboard
class ServizioStanze
class ServizioDispositivi
class ServizioAutomazioni
class ServizioLog
class ServizioSistema
class ServizioBackup

ServizioUtenti --> RepositoryUtenti
ServizioDashboard --> RepositoryStanze
ServizioDashboard --> RepositoryDispositivi
ServizioDashboard --> RepositoryEventi
ServizioStanze --> RepositoryStanze
ServizioDispositivi --> RepositoryDispositivi
ServizioAutomazioni --> RepositoryAutomazioni
ServizioLog --> RepositoryEventi
ServizioSistema --> RepositoryDispositivi
ServizioSistema --> RepositoryEventi
ServizioBackup --> RepositoryDatiSistema
ServizioBackup --> RepositoryEventi
@enduml
